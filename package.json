{
  "name": "huagent",
  "version": "4.0.0",
  "description": "Anime-powered AI coding agent CLI - the cutest, smartest coding companion in your terminal",
  "type": "module",
  "bin": {
    "huagent": "./bin/huagent.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "snapshot:tui": "node snapshot.mjs full",
    "verify": "npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "cli",
    "anime",
    "tui",
    "anthropic",
    "claude",
    "openai",
    "assistant"
  ],
  "author": "huanime",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "better-sqlite3": "^11.5.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "figures": "^6.1.0",
    "ink": "^5.0.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "nanoid": "^5.0.7",
    "openai": "^4.71.0",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
