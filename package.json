{
  "name": "huagent",
  "version": "6.3.1",
  "description": "AI coding agent CLI — 22 LLM providers, 101 models, wiki knowledge engine, OpenCode-inspired TUI, MIT-licensed",
  "type": "module",
  "bin": {
    "huagent": "./bin/huagent.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "snapshot:tui": "node scripts/snapshot.mjs full",
    "verify": "npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run verify",
    "prepack": "npm run build",
    "release": "npm run verify && npm publish",
    "release:beta": "npm run verify && npm publish --tag beta"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "cli",
    "tui",
    "terminal",
    "anthropic",
    "claude",
    "openai",
    "gemini",
    "deepseek",
    "groq",
    "mistral",
    "openrouter",
    "ollama",
    "assistant",
    "chatbot",
    "developer-tools",
    "llm",
    "ink"
  ],
  "author": "huanime",
  "license": "MIT",
  "homepage": "https://github.com/ahmdd4vd/Huagent",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmdd4vd/Huagent.git"
  },
  "bugs": {
    "url": "https://github.com/ahmdd4vd/Huagent/issues",
    "email": "huanime@users.noreply.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@types/chokidar": "^1.7.5",
    "@types/diff": "^7.0.2",
    "better-sqlite3": "^11.5.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "dotenv": "^16.4.5",
    "figures": "^6.1.0",
    "fuse.js": "^7.4.2",
    "ink": "^5.0.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "nanoid": "^5.0.7",
    "openai": "^4.71.0",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "terminal-link": "^5.0.0",
    "yauzl": "^3.4.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
